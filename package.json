{
	"name": "growth-capital-shopify-ai",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "vp dev --port 3000",
		"build": "vp build",
		"test": "vp test run",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"format": "vp fmt",
		"lint": "vp lint",
		"check": "vp check",
		"sync:deploy-config": "node scripts/render-shopify-deploy-config.mjs",
		"convex:dev": "convex dev",
		"convex:deploy": "convex deploy --yes",
		"convex:deploy:dev": "convex dev --once",
		"deploy:runtime": "npm run build && npm run convex:deploy:dev && wrangler deploy",
		"shopify:deploy": "npm run sync:deploy-config && shopify app deploy --config deploy --force",
		"theme:deploy": "npm run sync:deploy-config && shopify theme push --path theme --live --allow-live",
		"release": "npm run build && npm run convex:deploy && wrangler deploy && npm run theme:deploy",
		"deploy": "npm run build && npm run convex:deploy:dev && wrangler deploy && npm run shopify:deploy && npm run theme:deploy"
	},
	"dependencies": {
		"@ai-sdk/openai": "3.0.48",
		"@cloudflare/vite-plugin": "1.30.1",
		"@convex-dev/agent": "0.6.1",
		"@convex-dev/better-auth": "0.11.3",
		"@convex-dev/r2": "0.9.1",
		"@convex-dev/rate-limiter": "0.3.2",
		"@convex-dev/react-query": "0.1.0",
		"@convex-dev/resend": "0.2.3",
		"@headlessui/react": "2.2.9",
		"@react-email/components": "1.0.10",
		"@shopify/shopify-api": "13.0.0",
		"@tailwindcss/vite": "4.2.2",
		"@tanstack/react-devtools": "0.10.0",
		"@tanstack/react-form": "1.28.5",
		"@tanstack/react-query": "5.95.2",
		"@tanstack/react-query-devtools": "5.95.2",
		"@tanstack/react-router": "1.168.7",
		"@tanstack/react-router-devtools": "1.166.11",
		"@tanstack/react-router-ssr-query": "1.166.10",
		"@tanstack/react-start": "1.167.12",
		"@tanstack/react-table": "8.21.3",
		"@tanstack/router-plugin": "1.167.8",
		"ai": "6.0.140",
		"better-auth": "1.5.6",
		"clsx": "2.1.1",
		"convex": "1.34.1",
		"jose": "6.2.2",
		"jszip": "3.10.1",
		"lucide-react": "1.7.0",
		"motion": "12.38.0",
		"pdf-parse": "2.4.5",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"tailwind-merge": "3.5.0",
		"tailwindcss": "4.2.2",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@playwright/test": "1.58.2",
		"@tanstack/devtools-vite": "0.6.0",
		"@testing-library/dom": "10.4.1",
		"@testing-library/react": "16.3.2",
		"@types/node": "25.5.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "5.2.0",
		"jsdom": "29.0.1",
		"typescript": "5.9.3",
		"vite": "npm:@voidzero-dev/vite-plus-core@0.1.14",
		"vite-plus": "0.1.14",
		"vitest": "npm:@voidzero-dev/vite-plus-test@0.1.14",
		"wrangler": "4.77.0"
	},
	"overrides": {
		"vite": "npm:@voidzero-dev/vite-plus-core@0.1.14",
		"vitest": "npm:@voidzero-dev/vite-plus-test@0.1.14"
	},
	"packageManager": "npm@11.12.1"
}
